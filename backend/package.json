{
  "name": "samayak-backend",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "worker": "bun run src/worker.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:seed": "bunx prisma db seed",
    "db:studio": "bunx prisma studio",
    "db:generate": "bunx prisma generate",
    "db:reset": "bunx prisma migrate reset --force && bun run db:seed"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@prisma/client": "~7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@socket.io/bun-engine": "^0.1.1",
    "bullmq": "^5.78.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "ioredis": "^5.11.0",
    "jose": "^6.2.3",
    "pdf2pic": "^3.2.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "prisma": "~7.8.0",
    "typescript": "^6.0.3"
  },
  "module": "src/index.ts",
  "private": true
}
